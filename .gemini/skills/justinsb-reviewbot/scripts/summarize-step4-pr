import sys
import json
import subprocess
import argparse
import os
import re

def run_cmd(cmd, cwd=None, text=True):
    res = subprocess.run(cmd, capture_output=True, text=text, cwd=cwd)
    return res

def get_kcc_root():
    if os.environ.get("KCC_ROOT"):
        return os.path.abspath(os.environ.get("KCC_ROOT"))
    possible_paths = [
        "k8s-config-connector",
        os.path.expanduser("~/projects/kcc/reviewprs/k8s-config-connector")
    ]
    for path in possible_paths:
        if os.path.exists(path) and os.path.exists(os.path.join(path, ".git")):
            return os.path.abspath(path)
    print("Error: Could not locate k8s-config-connector repository root.", file=sys.stderr)
    sys.exit(1)

def check_fuzzer_guidelines(filepath):
    analysis = []
    if not os.path.exists(filepath):
        analysis.append("❌ Fuzzer file does not exist")
        return analysis

    with open(filepath, "r", encoding="utf-8") as f:
        content = f.read()

    if "RegisterKRMFuzzer" in content:
        analysis.append("✅ Fuzzer registered via `RegisterKRMFuzzer`")
    else:
        analysis.append("❌ Fuzzer registration (`RegisterKRMFuzzer`) not found")

    # Check for direct set insertion on SpecFields or StatusFields
    if ".SpecFields.Insert" in content or ".StatusFields.Insert" in content:
        analysis.append("❌ Violation: Fuzzer uses raw `.Insert` on SpecFields or StatusFields. Prefer fluent `.SpecField()` and `.StatusField()` methods.")
    else:
        analysis.append("✅ Fuzzer uses fluent `.SpecField()` / `.StatusField()` methods correctly")

    # Check for .labels handling
    if '".labels"' in content:
        if "Unimplemented_LabelsAnnotations" in content:
            analysis.append("✅ Correct: Labels are handled via `Unimplemented_LabelsAnnotations(\".labels\")`")
        else:
            analysis.append("❌ Violation: Labels are referenced but `Unimplemented_LabelsAnnotations` is not used. Must manage GCP labels via standard Kubernetes labels.")
    else:
        analysis.append("ℹ️ Labels not referenced in fuzzer (verify if resource has labels)")

    return analysis

def check_controller_guidelines(filepath):
    analysis = []
    if not os.path.exists(filepath):
        analysis.append("❌ Controller file does not exist")
        return analysis

    with open(filepath, "r", encoding="utf-8") as f:
        content = f.read()

    # Check common.NormalizeReferences
    if "NormalizeReferences" in content:
        analysis.append("✅ Calls `common.NormalizeReferences` in AdapterForObject")
    else:
        analysis.append("❌ Violation: `common.NormalizeReferences` call not found in controller. References must be normalized.")

    # Check compare<Resource> helper pattern
    compare_func = re.search(r"func compare\w+\(", content)
    if compare_func:
        analysis.append(f"✅ Found compare helper: `{compare_func.group(0).strip('(')}`")
    else:
        analysis.append("❌ Violation: Dedicated compare helper function (`compare<Resource>`) not found")

    # Check updateStatus and ReportDiff pattern
    if "UpdateStatus" in content:
        analysis.append("✅ Calls `UpdateStatus` on directbase.Operation")
    else:
        analysis.append("❌ Violation: `UpdateStatus` call not found")

    if "ReportDiff" in content:
        analysis.append("✅ Calls `structuredreporting.ReportDiff` or `ReportDiff` to report exact diffs")
    else:
        analysis.append("❌ Violation: `ReportDiff` call not found")

    return analysis

def extract_kind_from_controller(filepath):
    if not os.path.exists(filepath):
        return None
    with open(filepath, "r", encoding="utf-8") as f:
        content = f.read()
    match = re.search(r'registry\.RegisterModel\(krm\.(\w+)GVK', content)
    if match:
        return match.group(1)
    # Fallback to general pattern matching
    match = re.search(r'(\w+)GVK', content)
    if match:
        return match.group(1)
    return None

def check_static_config(filepath, controller_kinds, diff_files):
    analysis = []
    if not os.path.exists(filepath):
        return [f"⚠️ static_config.go not found at {filepath}"]
    with open(filepath, "r", encoding="utf-8") as f:
        content = f.read()

    # We want to check if each kind is configured in static_config.go
    for kind in controller_kinds:
        if kind in content:
            analysis.append(f"✅ Reconciler for `{kind}` is registered in static_config.go")
        else:
            analysis.append(f"❌ Reconciler for `{kind}` is NOT registered in static_config.go!")

    if not controller_kinds:
        # Fallback if no kinds detected
        if "static_config.go" in "".join(diff_files):
            analysis.append("✅ static_config.go was modified in this branch diff.")
        else:
            analysis.append("⚠️ static_config.go was NOT modified. Check if direct controller option registration is missing.")

    return analysis

def check_register_go(register_path, subdirs):
    if not os.path.exists(register_path):
        return [f"⚠️ register.go not found at {register_path}"]
    with open(register_path, "r", encoding="utf-8") as f:
        content = f.read()
    results = []
    for sd in subdirs:
        # sd is direct/<service_name>, e.g. direct/logging
        expected_import = f"pkg/controller/{sd}"
        if expected_import in content:
            results.append(f"✅ Package `{sd}` is registered in register.go")
        else:
            results.append(f"❌ Package `{sd}` is NOT registered in register.go. Controller init() will not be invoked!")
    return results

def main():
    parser = argparse.ArgumentParser(description="PR Review Summary Tool for Step 4 (Direct Controller Implementation)")
    parser.add_argument("pr", help="PR number or branch name")
    args = parser.parse_args()

    kcc_root = get_kcc_root()

    # Query PR info using gh
    print(f"Fetching PR #{args.pr} metadata from GitHub...")
    gh_cmd = ["gh", "pr", "view", args.pr, "--json", "number,title,state,mergeable,statusCheckRollup,headRefName"]
    res = run_cmd(gh_cmd, cwd=kcc_root)
    if res.returncode != 0:
        print(f"Error fetching PR: {res.stderr}", file=sys.stderr)
        sys.exit(1)

    pr_data = json.loads(res.stdout)
    pr_num = pr_data.get("number")
    title = pr_data.get("title")
    mergeable = pr_data.get("mergeable")
    head_branch = pr_data.get("headRefName")
    
    # Fetch latest master from remote first
    remote = "upstream"
    git_show_upstream = run_cmd(["git", "rev-parse", "--verify", "upstream/master"], cwd=kcc_root)
    if git_show_upstream.returncode != 0:
        remote = "origin"
    print(f"Fetching latest master from remote '{remote}'...")
    run_cmd(["git", "fetch", remote, "master"], cwd=kcc_root)

    # Check out the PR branch if not already checked out
    if not os.environ.get("KCC_ROOT"):
        current_branch = run_cmd(["git", "branch", "--show-current"], cwd=kcc_root).stdout.strip()
        if current_branch != head_branch:
            print(f"Checking out PR branch '{head_branch}'...")
            checkout_res = run_cmd(["gh", "pr", "checkout", str(pr_num)], cwd=kcc_root)
            if checkout_res.returncode != 0:
                print(f"Error checking out PR branch: {checkout_res.stderr}", file=sys.stderr)
                sys.exit(1)

    # 1. Check Mergeability / Conflicts
    conflict_status = "✅ No merge conflicts"
    if mergeable == "CONFLICTING":
        conflict_status = "❌ Merge conflicts detected with master"
    elif mergeable == "UNKNOWN":
        conflict_status = "⚠️ Mergeability status unknown (checks still running/processing on GitHub)"

    # 2. Check GitHub Actions status
    failing_checks = []
    pending_checks = []
    status_rollup = pr_data.get("statusCheckRollup") or []
    for check in status_rollup:
        conclusion = check.get("conclusion")
        status = check.get("status")
        state = check.get("state")
        name = check.get("name") or check.get("context")
        if conclusion == "FAILURE" or state == "FAILURE":
            failing_checks.append(name)
        elif status in ["IN_PROGRESS", "QUEUED", "REQUESTED", "WAITING"] or state in ["PENDING"]:
            pending_checks.append(name)

    actions_status = "✅ All GitHub Actions checks passed"
    if failing_checks:
        actions_status = f"❌ Failing checks:\n" + "\n".join([f"  - {c}" for c in failing_checks])
    elif pending_checks:
        actions_status = f"⏳ Pending checks:\n" + "\n".join([f"  - {c}" for c in pending_checks])

    # 3. Check CRD Diffs against merge-base
    base = "upstream/master"
    git_show_upstream = run_cmd(["git", "rev-parse", "--verify", "upstream/master"], cwd=kcc_root)
    if git_show_upstream.returncode != 0:
        base = "master"
        
    merge_base_res = run_cmd(["git", "merge-base", base, "HEAD"], cwd=kcc_root)
    if merge_base_res.returncode != 0:
        print("Error: Could not find merge-base.", file=sys.stderr)
        sys.exit(1)
    merge_base = merge_base_res.stdout.strip()

    print(f"Computing CRD schema diffs against merge-base {merge_base}...")
    diff_script_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "diff-crds")
    diff_res = run_cmd([diff_script_path, "--base", merge_base], cwd=kcc_root)
    
    crd_diff_status = "✅ No CRD schema differences detected"
    if diff_res.returncode != 0:
        crd_diff_status = f"❌ Error running diff-crds: {diff_res.stderr}"
    elif diff_res.stdout.strip():
        crd_diff_status = f"⚠️ CRD Schema differences detected:\n```\n{diff_res.stdout.strip()}\n```"

    # Find changed files in this PR (diff with merge base)
    git_diff_cmd = ["git", "diff", "--name-only", merge_base, "HEAD"]
    diff_files = run_cmd(git_diff_cmd, cwd=kcc_root).stdout.strip().split("\n")

    # Group files by category
    direct_dir_files = [f for f in diff_files if f.startswith("pkg/controller/direct/")]
    controller_files = [f for f in direct_dir_files if f.endswith("_controller.go")]
    fuzzer_files = [f for f in direct_dir_files if f.endswith("_fuzzer.go")]
    mapper_files = [f for f in direct_dir_files if f.endswith("_mapper.go") or "mapper" in f]
    register_file_mod = [f for f in diff_files if "register/register.go" in f]

    print("\n" + "="*40)
    print(f"### PR Step 4 Review Summary: #{pr_num} - {title}")
    print(f"Branch: `{head_branch}` (compared against merge-base `{merge_base[:8]}`)\n")
    print(f"**Merge Status**:\n{conflict_status}\n")
    print(f"**GitHub Actions Status**:\n{actions_status}\n")
    print(f"**CRD Schema Diffs**:\n{crd_diff_status}\n")

    print("**Direct Controller Implementation Analysis**:")

    # 1. Package Isolation
    if direct_dir_files:
        print("\n📦 **Package Isolation**:")
        # Check subdirectories used
        subdirs = set()
        for f in direct_dir_files:
            parts = f.split("/")
            if len(parts) > 4:
                subdirs.add("/".join(parts[2:4]))
        for sd in subdirs:
            print(f"  ✅ Files implemented in isolated package: `pkg/controller/direct/{sd}`")
    else:
        print("\n❌ **Package Isolation**: No files found under `pkg/controller/direct/`!")

    # 2. Reconciler Override Configuration (Brownfield)
    controller_kinds = []
    for cf in controller_files:
        kind = extract_kind_from_controller(os.path.join(kcc_root, cf))
        if kind:
            controller_kinds.append(kind)

    static_config_path = os.path.join(kcc_root, "pkg/controller/resourceconfig/static_config.go")
    static_analysis = check_static_config(static_config_path, controller_kinds, diff_files)
    print("\n⚙️ **Controller Opt-In Configuration**:")
    for a in static_analysis:
        print(f"  {a}")

    # 3. Import registration
    print("\n🔌 **Import Registration (`pkg/controller/direct/register/register.go`)**:")
    register_path = os.path.join(kcc_root, "pkg/controller/direct/register/register.go")
    register_analysis = check_register_go(register_path, subdirs)
    for a in register_analysis:
        print(f"  {a}")

    # 4. Controller Logic
    for cf in controller_files:
        print(f"\n🎮 **Controller**: `{cf}`")
        full_cf_path = os.path.join(kcc_root, cf)
        cf_analysis = check_controller_guidelines(full_cf_path)
        for a in cf_analysis:
            print(f"  {a}")

    # 5. Fuzzer Implementation
    for ff in fuzzer_files:
        print(f"\n🧬 **Fuzzer**: `{ff}`")
        full_ff_path = os.path.join(kcc_root, ff)
        ff_analysis = check_fuzzer_guidelines(full_ff_path)
        for a in ff_analysis:
            print(f"  {a}")

    print("="*40)

if __name__ == "__main__":
    main()
