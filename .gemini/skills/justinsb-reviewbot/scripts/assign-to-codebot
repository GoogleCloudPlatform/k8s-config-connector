import sys
import json
import subprocess
import time
import argparse
import os

def run_cmd(cmd, cwd=None, text=True):
    res = subprocess.run(cmd, capture_output=True, text=text, cwd=cwd)
    return res

def get_kcc_root():
    possible_paths = [
        "k8s-config-connector",
        os.path.expanduser("~/projects/kcc/reviewprs/k8s-config-connector")
    ]
    for path in possible_paths:
        if os.path.exists(path) and os.path.exists(os.path.join(path, ".git")):
            return os.path.abspath(path)
    print("Error: Could not locate k8s-config-connector repository root.", file=sys.stderr)
    sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description="Assign PR to codebot-robot and comment")
    parser.add_argument("pr", help="PR number")
    parser.add_argument("comment", help="Comment body")
    args = parser.parse_args()

    kcc_root = get_kcc_root()
    pr_num = args.pr

    # 1. Post comment
    print(f"Submitting comment to PR #{pr_num}...")
    comment_cmd = ["gh", "pr", "comment", pr_num, "--body", args.comment]
    res = run_cmd(comment_cmd, cwd=kcc_root)
    if res.returncode != 0:
        print(f"Error posting comment: {res.stderr}", file=sys.stderr)
        sys.exit(1)
    print("✓ Comment posted successfully.")

    # 2. Reassign PR
    print(f"Reassigning PR #{pr_num} to codebot-robot and unassigning self...")
    edit_cmd = ["gh", "pr", "edit", pr_num, "--add-assignee", "codebot-robot", "--remove-assignee", "@me"]
    res = run_cmd(edit_cmd, cwd=kcc_root)
    if res.returncode != 0:
        print(f"Error reassigning PR: {res.stderr}", file=sys.stderr)
        sys.exit(1)
    
    # 3. Verification loop
    print("Verifying assignment update on GitHub...")
    verified = False
    for attempt in range(1, 11):
        view_cmd = ["gh", "pr", "view", pr_num, "--json", "assignees"]
        view_res = run_cmd(view_cmd, cwd=kcc_root)
        if view_res.returncode == 0:
            try:
                data = json.loads(view_res.stdout)
                assignees = [a.get("login") for a in data.get("assignees", [])]
                
                # We want codebot-robot to be assigned
                has_codebot = "codebot-robot" in assignees
                
                # We want justinsb (or ourselves) to NOT be assigned
                has_self = "justinsb" in assignees
                
                if has_codebot and not has_self:
                    print(f"✓ Verification successful (attempt {attempt}): assignees={assignees}")
                    verified = True
                    break
            except Exception as e:
                print(f"Warning: Failed to parse assignees JSON: {e}", file=sys.stderr)
        
        print(f"Waiting for GitHub API update (attempt {attempt}/10)...")
        time.sleep(1.5)

    if not verified:
        print("Warning: Verification timed out. GitHub assignees list might not be updated yet.", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
