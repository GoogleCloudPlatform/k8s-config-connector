import sys
import json
import subprocess
import os

def get_kcc_root():
    possible_paths = [
        "k8s-config-connector",
        os.path.expanduser("~/projects/kcc/reviewprs/k8s-config-connector")
    ]
    for path in possible_paths:
        if os.path.exists(path) and os.path.exists(os.path.join(path, ".git")):
            return os.path.abspath(path)
    return os.getcwd()

def run_cmd(cmd, cwd=None, text=True):
    res = subprocess.run(cmd, capture_output=True, text=text, cwd=cwd)
    return res

def main():
    if len(sys.argv) < 2:
        print("Usage: summarize-pr <pr-number-or-branch>")
        sys.exit(1)
        
    pr_arg = sys.argv[1]
    kcc_root = get_kcc_root()
    
    # Query PR info using gh
    gh_cmd = ["gh", "pr", "view", pr_arg, "--json", "number,title,files"]
    res = run_cmd(gh_cmd, cwd=kcc_root)
    if res.returncode != 0:
        print(f"Error fetching PR info: {res.stderr}", file=sys.stderr)
        sys.exit(1)
        
    pr_data = json.loads(res.stdout)
    pr_num = pr_data.get("number")
    title = pr_data.get("title", "").lower()
    files = pr_data.get("files", [])
    
    # 1. Classification by PR Title
    step = None
    if "direct krm types" in title or "generate.sh" in title:
        step = 1
    elif "identity and refs" in title or "identity & refs" in title:
        step = 2
    elif "round-trip krm fuzzer" in title or "krm fuzzer" in title:
        step = 3
    elif "direct controller" in title or "e2e fixtures" in title:
        step = 4
    elif "implement export" in title:
        step = 5
        
    # 2. Fallback to Classification by Changed Files
    if step is None:
        has_controller = False
        has_identity_or_ref = False
        has_fuzzer = False
        has_types_or_generate = False
        
        for f in files:
            path = f.get("path", "")
            if path.endswith("_controller.go"):
                has_controller = True
            elif path.endswith("_identity.go") or path.endswith("_reference.go"):
                has_identity_or_ref = True
            elif path.endswith("_fuzzer.go"):
                has_fuzzer = True
            elif path.endswith("generate.sh") or path.endswith("_types.go") or "types.generated.go" in path:
                has_types_or_generate = True
                
        if has_controller:
            step = 4
        elif has_identity_or_ref:
            step = 2
        elif has_fuzzer:
            step = 3
        elif has_types_or_generate:
            step = 1
            
    # Default fallback
    if step is None:
        step = 1 # Default to step 1
        
    print(f"Classified PR #{pr_num} ('{pr_data.get('title')}') as Step {step}")
    
    # Call the corresponding script
    script_dir = os.path.dirname(os.path.abspath(__file__))
    if step == 1:
        script = os.path.join(script_dir, "summarize-step1-pr")
    elif step == 2:
        script = os.path.join(script_dir, "summarize-step2-pr")
    elif step == 3:
        script = os.path.join(script_dir, "summarize-step3-pr")
    elif step == 4:
        script = os.path.join(script_dir, "summarize-step4-pr")
    elif step == 5:
        # Step 5 doesn't have a specific review script yet, default to step 1/general review
        script = os.path.join(script_dir, "summarize-step1-pr")
    else:
        script = os.path.join(script_dir, "summarize-step1-pr")
        
    # Determine the git remote (upstream or origin)
    remote = "upstream"
    git_show_upstream = run_cmd(["git", "rev-parse", "--verify", "upstream/master"], cwd=kcc_root)
    if git_show_upstream.returncode != 0:
        remote = "origin"
        
    # Fetch the PR head branch to a temporary local review branch
    temp_branch = f"review-pr-{pr_num}"
    print(f"Fetching PR #{pr_num} from remote '{remote}' to branch '{temp_branch}'...")
    fetch_cmd = ["git", "fetch", remote, f"pull/{pr_num}/head:{temp_branch}"]
    fetch_res = run_cmd(fetch_cmd + ["--force"], cwd=kcc_root)
    if fetch_res.returncode != 0:
        print(f"Error fetching PR branch: {fetch_res.stderr}", file=sys.stderr)
        sys.exit(1)
        
    # Create git worktree
    parent_dir = os.path.abspath(os.path.join(script_dir, "..", "..", "..", "..")) # parent root
    worktree_path = os.path.join(parent_dir, "worktrees", temp_branch)
    os.makedirs(os.path.dirname(worktree_path), exist_ok=True)
    
    print(f"Adding git worktree at '{worktree_path}'...")
    worktree_cmd = ["git", "worktree", "add", worktree_path, temp_branch]
    worktree_res = run_cmd(worktree_cmd, cwd=kcc_root)
    if worktree_res.returncode != 0:
        print(f"Error adding worktree: {worktree_res.stderr}", file=sys.stderr)
        # Cleanup branch if worktree creation failed
        run_cmd(["git", "branch", "-D", temp_branch], cwd=kcc_root)
        sys.exit(1)
        
    # Set KCC_ROOT env var
    os.environ["KCC_ROOT"] = worktree_path
    
    try:
        # Run step script as a subprocess
        subprocess.run([script] + sys.argv[1:], env=os.environ, check=True)
        print(f"\nℹ️ Worktree kept at: {worktree_path}")
        print(f"To inspect files, view under the worktree directory.")
    except subprocess.CalledProcessError as e:
        print(f"Error executing step script: {e}", file=sys.stderr)
        # On error we can clean up to avoid leaving broken worktrees
        print("Cleaning up worktree and temporary branch after failure...")
        run_cmd(["git", "worktree", "remove", worktree_path], cwd=kcc_root)
        run_cmd(["git", "branch", "-D", temp_branch], cwd=kcc_root)

if __name__ == "__main__":
    main()
