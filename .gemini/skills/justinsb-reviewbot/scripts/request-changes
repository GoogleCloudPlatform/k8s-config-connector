import sys
import json
import subprocess
import argparse
import os

def run_cmd(cmd, cwd=None, text=True):
    res = subprocess.run(cmd, capture_output=True, text=text, cwd=cwd)
    return res

def get_kcc_root():
    possible_paths = [
        "k8s-config-connector",
        os.path.expanduser("~/projects/kcc/reviewprs/k8s-config-connector")
    ]
    for path in possible_paths:
        if os.path.exists(path) and os.path.exists(os.path.join(path, ".git")):
            return os.path.abspath(path)
    return os.getcwd()

def main():
    parser = argparse.ArgumentParser(description="Request changes on a PR with inline comments and reassign to codebot-robot")
    parser.add_argument("pr", help="PR number")
    parser.add_argument("body", help="Overall review body text")
    parser.add_argument("comments", nargs="*", help="Inline comments in format 'path:line:comment'")
    args = parser.parse_args()

    kcc_root = get_kcc_root()
    pr_num = args.pr

    # Parse inline comments
    comments_payload = []
    for c in args.comments:
        parts = c.split(":", 2)
        if len(parts) < 3:
            print(f"Error: Invalid comment format '{c}'. Must be 'path:line:comment'", file=sys.stderr)
            sys.exit(1)
        path, line_str, comment_text = parts
        try:
            line_num = int(line_str)
        except ValueError:
            print(f"Error: Invalid line number '{line_str}' in comment '{c}'", file=sys.stderr)
            sys.exit(1)
        
        comments_payload.append({
            "path": path,
            "line": line_num,
            "side": "RIGHT",
            "body": comment_text
        })

    # Prepare gh api command
    # Endpoint: POST /repos/{owner}/{repo}/pulls/{pull_number}/reviews
    api_path = f"/repos/GoogleCloudPlatform/k8s-config-connector/pulls/{pr_num}/reviews"
    
    payload = {
        "body": args.body,
        "event": "REQUEST_CHANGES",
    }
    if comments_payload:
        payload["comments"] = comments_payload

    # Run gh api passing payload via stdin
    api_cmd = [
        "gh", "api",
        "-H", "Accept: application/vnd.github+json",
        "-H", "X-GitHub-API-Version: 2022-11-28",
        api_path,
        "--input", "-"
    ]

    print(f"Submitting changes request review to PR #{pr_num}...")
    # Run command and write stdin
    res = subprocess.run(api_cmd, input=json.dumps(payload), capture_output=True, text=True, cwd=kcc_root)
    if res.returncode != 0:
        print(f"Error submitting review: {res.stderr}", file=sys.stderr)
        sys.exit(1)
    print("✓ Review submitted successfully.")

    # Assign back to codebot-robot using edit command
    print(f"Reassigning PR #{pr_num} to codebot-robot and unassigning self...")
    edit_cmd = ["gh", "pr", "edit", pr_num, "--add-assignee", "codebot-robot", "--remove-assignee", "@me"]
    res = run_cmd(edit_cmd, cwd=kcc_root)
    if res.returncode != 0:
        print(f"Error reassigning PR: {res.stderr}", file=sys.stderr)
        sys.exit(1)
    print("✓ Reassigned to codebot-robot successfully.")

    # Cleanup worktree and temporary branch
    temp_branch = f"review-pr-{pr_num}"
    worktree_path = os.path.join(kcc_root, "worktrees", temp_branch)
    if os.path.exists(worktree_path):
        print(f"Cleaning up worktree at '{worktree_path}'...")
        run_cmd(["git", "worktree", "remove", worktree_path], cwd=kcc_root)
    
    # Check if branch exists
    git_show_branch = run_cmd(["git", "show-ref", "--verify", "--quiet", f"refs/heads/{temp_branch}"], cwd=kcc_root)
    if git_show_branch.returncode == 0:
        print(f"Cleaning up branch '{temp_branch}'...")
        run_cmd(["git", "branch", "-D", temp_branch], cwd=kcc_root)



if __name__ == "__main__":
    main()
