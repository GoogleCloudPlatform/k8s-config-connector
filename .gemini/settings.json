// ~/.gemini/settings.json
{
    "mcpServers": {
        "github": {
            "httpUrl": "https://api.githubcopilot.com/mcp/",
            "headers": {
                "Authorization": "Bearer $GITHUB_MCP_PAT"
            }
        },
        "crd": {
            "command": "dev/mcp/crd-mcp-server",
            "args": [
                "stdio"
            ]
        }
    }
}
