apiVersion: bigquery.cnrm.cloud.google.com/v1beta1
kind: BigQueryTable
metadata:
  annotations:
    cnrm.cloud.google.com/project-id: ${projectId}
  labels:
    cnrm-test: "true"
    managed-by-cnrm: "true"
  name: bigquerytable-${uniqueId}
spec:
  datasetRef:
    external: bigquerydataset${uniqueId}
  description: An UPDATED BigQuery Table that inherits its encryption key from its
    parent dataset.
  encryptionConfiguration:
    kmsKeyRef:
      external: projects/${projectId}/locations/us-central1/keyRings/kmskeyring-${uniqueId}/cryptoKeys/kmscryptokey-${uniqueId}
  friendlyName: BigQueryTable Inherited Encryption Example
  resourceID: bigquerytable-${uniqueId}
  schema: '[{"mode":"REQUIRED","name":"name","type":"STRING"},{"name":"age","type":"INTEGER"}]'