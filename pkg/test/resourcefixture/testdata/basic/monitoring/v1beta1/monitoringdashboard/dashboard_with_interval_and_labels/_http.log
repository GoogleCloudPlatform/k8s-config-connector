POST https://monitoring.googleapis.com/v1/projects/${projectId}/dashboards?%24alt=json%3Benum-encoding%3Dint
Content-Type: application/json
User-Agent: kcc/${kccVersion} (+https://github.com/GoogleCloudPlatform/k8s-config-connector) kcc/controller-manager/${kccVersion}
X-Goog-Request-Params: parent=projects%2F${projectId}

{
  "displayName": "Dashboard with Interval and Labels",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "timeSeriesTable": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": 12
                  },
                  "filter": "metric.type=\"compute.googleapis.com/instance/cpu/utilization\" resource.type=\"gce_instance\"",
                  "pickTimeSeriesFilter": {
                    "direction": 1,
                    "interval": {
                      "endTime": "2026-03-04T00:00:00Z"
                    },
                    "numTimeSeries": 5,
                    "rankingMethod": 1
                  }
                }
              }
            }
          ]
        },
        "title": "Top 5 GCE Instances by CPU"
      },
      {
        "title": "Chart with Thresholds",
        "xyChart": {
          "dataSets": [
            {
              "plotType": 1,
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"compute.googleapis.com/instance/cpu/utilization\" resource.type=\"gce_instance\""
                }
              }
            }
          ],
          "thresholds": [
            {
              "label": "Critical",
              "value": 0.8
            }
          ]
        }
      }
    ]
  },
  "labels": {
    "user-label": "user-value"
  },
  "name": "projects/${projectId}/dashboards/${dashboardID}"
}

