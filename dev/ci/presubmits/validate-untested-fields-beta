set -o errexit
set -o nounset
set -o pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

# Determine the base branch for comparison
# In GitHub Actions, GITHUB_BASE_REF is set for PRs.
BASE_BRANCH="${GITHUB_BASE_REF:-}"

# For merge_group or other events, try to derive it or default to master
if [[ -z "${BASE_BRANCH}" ]]; then
  # If we are in a merge_group, GITHUB_REF is refs/heads/gh-readonly-queue/master/...
  # We can try to extract the target branch name.
  if [[ "${GITHUB_REF:-}" == refs/heads/gh-readonly-queue/* ]]; then
    BASE_BRANCH=$(echo "${GITHUB_REF}" | sed 's|refs/heads/gh-readonly-queue/||' | cut -d'/' -f1)
  else
    BASE_BRANCH="master"
  fi
fi

# Allow overriding the comparison reference for local testing
COMPARISON_REF="${COMPARISON_REF:-origin/${BASE_BRANCH}}"

# Extract the remote name from the COMPARISON_REF (e.g., 'origin' from 'origin/master')
REMOTE_NAME=$(echo "${COMPARISON_REF}" | cut -d'/' -f1)
REMOTE_BRANCH=$(echo "${COMPARISON_REF}" | cut -d'/' -f2-)

# Fetch the base branch to ensure it is available for comparison
echo "Fetching ${REMOTE_NAME} ${REMOTE_BRANCH}..."
if ! git fetch "${REMOTE_NAME}" "${REMOTE_BRANCH}" --quiet; then
  echo "Warning: git fetch failed. Checking if ${COMPARISON_REF} exists locally..."
  if ! git rev-parse "${COMPARISON_REF}" > /dev/null 2>&1; then
    echo "Error: ${COMPARISON_REF} not found locally and fetch failed."
    exit 1
  fi
fi

# Robustly identify the merge base
if git rev-parse FETCH_HEAD > /dev/null 2>&1; then
  BASE_COMMIT=$(git merge-base FETCH_HEAD HEAD)
else
  BASE_COMMIT=$(git merge-base "${COMPARISON_REF}" HEAD)
fi
COMMIT_HEAD="HEAD"

MISSING_FIELDS_FILE="${REPO_ROOT}/tests/apichecks/testdata/exceptions/missingfields.txt"
# Checks for a partial string to determine if the missing field is a reference field
MISSING_REFERENCE_STRING="neither 'external' nor 'name' are set"

echo "Checking untested fields for range: ${BASE_COMMIT}..${COMMIT_HEAD}"

# Get the lines added to missingfields.txt in the current branch compared to master
added_lines=$(git diff --unified=0 "${BASE_COMMIT}..${COMMIT_HEAD}" "${MISSING_FIELDS_FILE}" | grep '^+[^+]' | sed 's/^+//' || true)
# Filter for missing reference fields
# HACK: Temporarily ignore memorystoreInstanceServiceAttachment
added_reference_lines=$(echo "${added_lines}" | grep "${MISSING_REFERENCE_STRING}" | grep -v memorystoreInstanceServiceAttachment || true)

if [[ -n "${added_reference_lines}" ]]; then
  echo "ERROR: Untested reference fields detected."
  echo "The following lines were added in ${MISSING_FIELDS_FILE}:"
  echo "${added_reference_lines}"
  echo "Please ensure the reference field(s) are tested."
  exit 1
elif [[ -n "${added_lines}" ]]; then
  echo "WARNING: Untested fields detected."
  echo "The following lines were added in ${MISSING_FIELDS_FILE}::"
  echo "${added_lines}"
  echo "Please ensure they are intentional and covered by tests in the future."
  exit 0
else
  echo "No new lines were added to ${MISSING_FIELDS_FILE}."
  exit 0
fi
