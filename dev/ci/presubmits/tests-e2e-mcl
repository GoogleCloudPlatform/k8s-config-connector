set -o errexit
set -o nounset
set -o pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

# Install a strictly pinned version of BATS-core for the CI environment
if ! command -v bats &> /dev/null; then
  echo ">>> Installing pinned BATS (v1.11.0)..."
  curl -sSL https://github.com/bats-core/bats-core/archive/refs/tags/v1.11.0.tar.gz | tar -xz -C /tmp
  sudo /tmp/bats-core-1.11.0/install.sh /usr/local
fi

# Install kind if not present
if ! command -v kind &> /dev/null; then
  echo ">>> Installing kind..."
  curl -Lo ./kind https://kind.sigs.k8s.io/dl/v0.22.0/kind-linux-amd64
  chmod +x ./kind
  sudo mv ./kind /usr/local/bin/kind
fi

# Install kubectl if not present
if ! command -v kubectl &> /dev/null; then
  echo ">>> Installing kubectl..."
  curl -LO "https://dl.k8s.io/release/v1.30.0/bin/linux/amd64/kubectl"
  chmod +x ./kubectl
  sudo mv ./kubectl /usr/local/bin/kubectl
fi

# Run the HA/DR E2E tests using Kind and BATS
./tests/e2e/mcl/run-ha-e2e-tests.sh
