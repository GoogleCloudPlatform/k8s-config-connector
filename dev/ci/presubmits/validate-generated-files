import os
import subprocess
import sys


def main():
    """Runs the validation logic."""

    repo_root = subprocess.check_output(["git", "rev-parse", "--show-toplevel"]).strip().decode("utf-8")
    os.chdir(repo_root)

    print("Running 'make generate' to update all generated files...")
    subprocess.run(["make", "generate"], check=True)

    # Check for any uncommitted changes
    diff_output = subprocess.check_output(["git", "diff", "--name-only"]).decode("utf-8").strip()
    if diff_output:
        print("Full diff:")
        # Use subprocess.run to simply execute and print the output of git diff
        subprocess.run(["git", "--no-pager", "diff"])
        print("ERROR: Generated files out-of-date. Please run 'make generate' locally and update your PR.")
        print("<hint_for_agent>Generated files out of date.  Run 'make generate' to regenerate, and then update your PR.</hint_for_agent>")
        print("Affected files:")
        print(diff_output)
        sys.exit(1)
    else:
        print("Success: All generated files are up-to-date.")

if __name__ == "__main__":
    main()
