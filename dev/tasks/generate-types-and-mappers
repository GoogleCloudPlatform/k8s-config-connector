set -o errexit
set -o nounset
set -o pipefail

# Disable core dump file creation during parallel generator execution
ulimit -c 0 2>/dev/null || true

# Clean up any abandoned /tmp/kcc-gocache-* directories left behind by previous interrupted runs
rm -rf /tmp/kcc-gocache-* 2>/dev/null || true

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd ${REPO_ROOT}

# Pre-compile controllerbuilder and shared googleapis proto descriptors once upfront
pushd dev/tools/controllerbuilder
./generate-proto.sh
popd

# For efficiency during parallel package generation:
# 1. SKIP_GENERATE_CRDS=1: Defer expensive CRD YAML generation to a single step at the end.
# 2. SKIP_GENERATE_PROTOS=1: Reuse the googleapis.pb compiled upfront rather than re-compiling protos for every package.
export SKIP_GENERATE_CRDS=1
export SKIP_GENERATE_PROTOS=1

# Collect all service generate.sh scripts to execute
scripts=()
for f in $(find apis -name "generate.sh" | sort); do
    # Skip some generate.sh scripts that are not up to date
    # TODO: Fix these!

    if [[ "${f}" == *"backupdr"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"bigquerybiglake"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"bigtable"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"composer"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"contentwarehouse"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"datastream"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"discoveryengine"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"documentai"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"edgecontainer"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"gkebackup"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"orgpolicy"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"speech"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"tpu"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"vertexai"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"vmwareengine"* ]]; then
        echo "Skipping ${f}"
        continue
    fi

    scripts+=("${f}")
done

# Determine available CPU cores for parallel execution (defaults to 8 if undetectable)
NUM_WORKERS="${PARALLELISM:-$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 8)}"
echo "Running ${#scripts[@]} generator scripts in parallel with ${NUM_WORKERS} workers..."

# Create a temporary parent directory for worker Go build caches
export GOCACHE_BASE="/tmp/kcc-gocache-$$"
mkdir -p "${GOCACHE_BASE}"

# Guarantee cleanup of GOCACHE_BASE on script completion or interruption (SIGINT, SIGTERM, EXIT)
cleanup_gocache_base() {
    rm -rf "${GOCACHE_BASE}" 2>/dev/null || true
}
trap cleanup_gocache_base EXIT INT TERM

# Worker function to execute a single generate.sh script in parallel with its own isolated Go build cache
run_one() {
    local f="$1"
    
    # Create an isolated temporary GOCACHE directory per worker process.
    # This prevents race conditions and lock collisions in standard ~/.cache/go-build
    # when multiple Go compiler processes run simultaneously.
    local worker_cache
    worker_cache=$(mktemp -d "${GOCACHE_BASE}/worker-XXXXXX")
    export GOCACHE="${worker_cache}"
    export GOTMPDIR="${worker_cache}"

    # Ensure worker cache directory is cleaned up when this worker subshell finishes
    trap 'rm -rf "${worker_cache}"' EXIT

    echo "running ${f}"
    if ! ./${f}; then
        echo "ERROR running ${f}" >&2
        exit 1
    fi
}
export -f run_one
export GOCACHE_BASE

# Stream the list of generate.sh paths into xargs -P to process up to NUM_WORKERS scripts concurrently
printf "%s\n" "${scripts[@]}" | xargs -P "${NUM_WORKERS}" -I {} bash -c 'run_one "$@"' _ {}

# Clean up parent Go cache directory
cleanup_gocache_base

# Now we generate CRDs once for all updated packages
unset SKIP_GENERATE_CRDS
unset SKIP_GENERATE_PROTOS
echo "Cleaning Go build cache to prevent stale metadata compilation issues"
go clean -cache
echo "Generating CRDs"
dev/tasks/generate-crds
