set -o errexit
set -o nounset
set -o pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd ${REPO_ROOT}

pushd dev/tools/controllerbuilder
./generate-proto.sh
popd

# For efficiency, we generate CRDs only once at the end
export SKIP_GENERATE_CRDS=1
export SKIP_GENERATE_PROTOS=1

# Collect all generate.sh scripts to run
scripts=()
for f in $(find apis -name "generate.sh" | sort); do
    # Skip some generate.sh scripts that are not up to date
    # TODO: Fix these!

    if [[ "${f}" == *"backupdr"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"bigquerybiglake"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"bigtable"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"composer"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"contentwarehouse"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"datastream"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"discoveryengine"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"documentai"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"edgecontainer"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"gkebackup"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"orgpolicy"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"speech"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"tpu"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"vertexai"* ]]; then
        echo "Skipping ${f}"
        continue
    fi
    if [[ "${f}" == *"vmwareengine"* ]]; then
        echo "Skipping ${f}"
        continue
    fi

    scripts+=("${f}")
done

NUM_WORKERS="${PARALLELISM:-$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 8)}"
echo "Running ${#scripts[@]} generator scripts in parallel with ${NUM_WORKERS} workers..."

export GOCACHE_BASE="/tmp/kcc-gocache-$$"
mkdir -p "${GOCACHE_BASE}"

run_one() {
    local f="$1"
    local script_hash
    script_hash=$(echo "${f}" | md5sum | awk '{print $1}')
    local worker_cache="${GOCACHE_BASE}/${script_hash}"
    mkdir -p "${worker_cache}"
    export GOCACHE="${worker_cache}"

    echo "running ${f}"
    if ! ./${f}; then
        echo "ERROR running ${f}" >&2
        rm -rf "${worker_cache}"
        exit 1
    fi
    rm -rf "${worker_cache}"
}
export -f run_one
export GOCACHE_BASE

printf "%s\n" "${scripts[@]}" | xargs -P "${NUM_WORKERS}" -I {} bash -c 'run_one "$@"' _ {}

rm -rf "${GOCACHE_BASE}"

# Now we generate CRDs
unset SKIP_GENERATE_CRDS
unset SKIP_GENERATE_PROTOS
echo "Cleaning Go build cache to prevent stale metadata compilation issues"
go clean -cache
echo "Generating CRDs"
dev/tasks/generate-crds
