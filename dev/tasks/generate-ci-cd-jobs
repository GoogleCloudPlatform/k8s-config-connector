set -o errexit
set -o nounset
set -o pipefail

set -x

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd ${REPO_ROOT}


for group in $(rgrep --no-filename '^[ ]*group:' config/crds | sort | uniq | awk '{print $2}'); do
  if [[ "${group}" == "" ]]; then
    continue
  fi
  if [[ "${group}" != *.cnrm.cloud.google.com ]] ; then
    echo "Skipping non-CNRM group: ${group}"
    continue
  fi

  short=$(echo ${group} | sed s@.cnrm.cloud.google.com@@g)
  if [[ "${short}" == "blockchainnodeengine" || "${short}" == "videostitcher" ]]; then
    echo "Skipping ${short}"
    continue
  fi

  extra_services="${short}.googleapis.com"
  case ${short} in
    "analytics") extra_services="analyticsadmin.googleapis.com" ;;
    "bigqueryanalyticshub") extra_services="analyticshub.googleapis.com" ;;
    "bigquerybiglake") extra_services="biglake.googleapis.com" ;;
    "certificatemanager") extra_services="certificatemanager.googleapis.com servicedirectory.googleapis.com privateca.googleapis.com" ;;
    "clouddms") extra_services="datamigration.googleapis.com" ;;
    "cloudfunctions2") extra_services="cloudfunctions.googleapis.com" ;;
    "cloudids") extra_services="ids.googleapis.com" ;;
    "containerattached") extra_services="gkemulticloud.googleapis.com" ;;
    "dialogflowcx") extra_services="dialogflow.googleapis.com" ;;
    "filestore") extra_services="file.googleapis.com" ;;
    "kms") extra_services="cloudkms.googleapis.com" ;;
    "mlengine") extra_services="ml.googleapis.com" ;;
    "resourcemanager") extra_services="cloudresourcemanager.googleapis.com" ;;
    "sql") extra_services="sqladmin.googleapis.com" ;;
    "tags") extra_services="cloudresourcemanager.googleapis.com" ;;
  esac

cat > ${REPO_ROOT}/dev/ci/periodics/e2e-service-${short} <<EOF
