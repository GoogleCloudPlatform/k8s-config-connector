set -o errexit
set -o nounset
set -o pipefail

PROJECT_ID="${1:-${E2E_PROJECT_ID:-}}"

if [[ -z "${PROJECT_ID}" ]]; then
  echo "Usage: $0 <PROJECT_ID>"
  echo "  or: E2E_PROJECT_ID=<PROJECT_ID> $0"
  exit 1
fi

echo "Setting up containerd test secrets in project: ${PROJECT_ID}"

# 1. Get GKE Service Agent email & Project Number
PROJECT_NUM=$(gcloud projects describe "${PROJECT_ID}" --format="value(projectNumber)")
GKE_SA="service-${PROJECT_NUM}@container-engine-robot.iam.gserviceaccount.com"

# Create a temporary directory for cert generation
TMP_DIR=$(mktemp -d)
trap 'rm -rf "${TMP_DIR}"' EXIT

# 2. Generate v1 and v2 self-signed CA cert, Client cert, and Client key locally
openssl req -x509 -newkey rsa:2048 -keyout "${TMP_DIR}/ca_v1.key" -out "${TMP_DIR}/ca_v1.crt" -days 3650 -nodes -subj "/CN=kcc-test-ca-v1"
openssl req -x509 -newkey rsa:2048 -keyout "${TMP_DIR}/client_v1.key" -out "${TMP_DIR}/client_v1.crt" -days 3650 -nodes -subj "/CN=kcc-test-client-v1"

openssl req -x509 -newkey rsa:2048 -keyout "${TMP_DIR}/ca_v2.key" -out "${TMP_DIR}/ca_v2.crt" -days 3650 -nodes -subj "/CN=kcc-test-ca-v2"
openssl req -x509 -newkey rsa:2048 -keyout "${TMP_DIR}/client_v2.key" -out "${TMP_DIR}/client_v2.crt" -days 3650 -nodes -subj "/CN=kcc-test-client-v2"

# 3. Helper function to create Secret Manager secret and grant GKE SA access
setup_secret() {
  local SECRET_NAME=$1
  local V1_FILE_PATH=$2
  local V2_FILE_PATH=$3

  echo "Creating secret ${SECRET_NAME} in project ${PROJECT_ID}..."
  gcloud secrets create "${SECRET_NAME}" --replication-policy="automatic" --project="${PROJECT_ID}" || true
  
  # Ensure version 1 exists
  if ! gcloud secrets versions describe 1 --secret="${SECRET_NAME}" --project="${PROJECT_ID}" >/dev/null 2>&1; then
    gcloud secrets versions add "${SECRET_NAME}" --data-file="${V1_FILE_PATH}" --project="${PROJECT_ID}"
  fi

  # Ensure version 2 exists
  if ! gcloud secrets versions describe 2 --secret="${SECRET_NAME}" --project="${PROJECT_ID}" >/dev/null 2>&1; then
    gcloud secrets versions add "${SECRET_NAME}" --data-file="${V2_FILE_PATH}" --project="${PROJECT_ID}"
  fi

  echo "Granting GKE SA secretAccessor on ${SECRET_NAME}..."
  gcloud secrets add-iam-policy-binding "${SECRET_NAME}" \
    --member="serviceAccount:${GKE_SA}" \
    --role="roles/secretmanager.secretAccessor" \
    --project="${PROJECT_ID}"
}

setup_secret "kcc-test-ca-cert" "${TMP_DIR}/ca_v1.crt" "${TMP_DIR}/ca_v2.crt"
setup_secret "kcc-test-client-cert" "${TMP_DIR}/client_v1.crt" "${TMP_DIR}/client_v2.crt"
setup_secret "kcc-test-client-key" "${TMP_DIR}/client_v1.key" "${TMP_DIR}/client_v2.key"

echo "Successfully set up containerd test secrets in project ${PROJECT_ID}."
