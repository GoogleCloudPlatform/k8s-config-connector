        with:
          fetch-depth: 0
      - uses: ./dev/actions/cache-go
      - name: "Run ${f}"
        run: |
          ./${f}
        env:
          ARTIFACTS: /tmp/artifacts
      - name: "Upload artifacts"
        uses: actions/upload-artifact@604373da71285a27a30c7ad4f1e3d17d84f26c01 # v4
        if: \${{ !cancelled() }}
        with:
          name: artifacts-${name}
          path: /tmp/artifacts/

EOF
    continue
    fi

    if [[ "${name}" == tests-e2e-* || "${name}" == tests-scenarios-* ]]; then
cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
    needs: unit-tests
EOF
    fi

    if [[ "${name}" == "validate-untested-fields" ]]; then
cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
    timeout-minutes: 60
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v6.1.0
        with:
          fetch-depth: 0
