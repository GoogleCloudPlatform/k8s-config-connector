    else
cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
    timeout-minutes: 60
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v6.1.0
EOF
    fi

    if [[ "${name}" == "unit-tests" || "${name}" == "unit-tests-operator" ]]; then
cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
      - name: Free up disk space
        run: dev/tasks/free-disk-space-on-github-actions-runner
EOF
    fi

cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
