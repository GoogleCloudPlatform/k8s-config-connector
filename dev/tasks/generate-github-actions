EOF

    # TODO: We should look at the script to see if it needs gcloud
    if [[ "${name}" == "test-mockgcp" || "${name}" == "unit-tests" || "${name}" == "unit-tests-operator" ]]; then
cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
      - uses: 'google-github-actions/setup-gcloud@26f734c32e911548d772283a19e8b922605f3d86' # v3.0.0
        with:
          version: '546.0.0'
          install_components: 'alpha,beta'
EOF
    fi

    if [[ "${name}" == "validate-untested-fields" ]]; then
cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
      - name: "Run ${f}"
        run: |
          ./${f}
        env:
          COMMIT_HEAD: \${{ github.event.pull_request.head.sha }}
          BASE_COMMIT: \${{ github.event.pull_request.base.sha }}
          ARTIFACTS: /tmp/artifacts
EOF
    else
cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
      - name: "Run ${f}"
        run: |
          ./${f}
        env:
          ARTIFACTS: /tmp/artifacts
EOF
    fi

cat >> ${REPO_ROOT}/.github/workflows/ci-presubmit.yaml <<EOF
      - name: "Upload artifacts"
        uses: actions/upload-artifact@604373da71285a27a30c7ad4f1e3d17d84f26c01 # v4
        if: \${{ !cancelled() }}
        with:
          name: artifacts-${name}
          path: /tmp/artifacts/

