    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v6.1.0
        with:
          fetch-depth: 0
      - name: Free up disk space
        run: dev/tasks/free-disk-space-on-github-actions-runner
      - uses: actions/setup-go@4a3601121dd01d1626a1e23e37211e3254c1c06c # v6.4.0
        with:
          go-version-file: 'go.mod'
          cache: false
      - name: golangci-lint
        uses: golangci/golangci-lint-action@ba0d7d2d30d271b5e41010972e01a2708ce6222d # v9.3.0
        with:
          version: v2.9.0
          args: --timeout=20m
EOF
    continue
    fi

    if [[ "${name}" == "license-lint" ]]; then
