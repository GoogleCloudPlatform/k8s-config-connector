# This script cherry-picks (merged) PRs from the main branch to a release branch,
# and then sends a github PR for the changes.
#
# It assumes that the gh CLI is installed and authenticated.
#
# Usage: dev/tasks/cherry-pick <release-branch> <pr-number> [--force]

import os
import subprocess
import sys
import tempfile
import json

def run(cmd, **kwargs):
    print(f"Running command: {' '.join(cmd)}")
    try:
        return subprocess.run(cmd, check=True, capture_output=True, text=True, **kwargs)
    except subprocess.CalledProcessError as e:
        print(f"Command failed with exit code {e.returncode}")
        print(f"Stderr: {e.stderr}")
        print(f"Stdout: {e.stdout}")
        raise


def main():
    if len(sys.argv) < 3:
        print("Usage: dev/tasks/cherry-pick <release-branch> <pr-number> [--force]")
        sys.exit(1)
    release_branch = sys.argv[1]
    pr_number = sys.argv[2]
    force = "--force" in sys.argv

    repo_root = run(["git", "rev-parse", "--show-toplevel"]).stdout.strip()
    os.chdir(repo_root)

    # Get the PR info
    print(f"Fetching information for PR #{pr_number}...")
    pr_info_results = run(["gh", "pr", "view", pr_number, "--json", "commits,title,body"])
    pr_info = json.loads(pr_info_results.stdout)

    if not pr_info.get('commits'):
        print(f"Error: No commits found for PR #{pr_number}.")
        sys.exit(1)

    pr_title = f"cherry-pick: {release_branch}: {pr_info['title']}"
    pr_body = "Cherry picking PR #" + pr_number + "\n\n" + pr_info['body']

    branch_name = f"cherry-pick-{pr_number}-{release_branch}"
    github_username = run(["gh", "api", "user", "-q", ".login"]).stdout.strip()
    user_fork = f"https://github.com/{github_username}/k8s-config-connector"

    # Ensure 'upstream' remote exists
    remotes = run(["git", "remote"]).stdout.split()
    if "upstream" not in remotes:
        print("Error: 'upstream' remote not found.")
        print("This script expects a remote named 'upstream' pointing to the main repository.")
        print("Please add it with: git remote add upstream https://github.com/GoogleCloudPlatform/k8s-config-connector.git")
        sys.exit(1)

    # Fetch latest from upstream to ensure we have the latest release branch
    print("Fetching latest from upstream...")
    run(["git", "fetch", "upstream"])

    # Check for existing local branch
    branch_exists_locally = subprocess.run(["git", "rev-parse", "--verify", branch_name], capture_output=True).returncode == 0
    if branch_exists_locally:
        if force:
            print(f"Deleting existing local branch {branch_name}...")
            run(["git", "branch", "-D", branch_name])
        else:
            print(f"Error: local branch '{branch_name}' already exists.")
            print(f"Use --force to overwrite it, or delete it manually with 'git branch -D {branch_name}'.")
            sys.exit(1)

    # If force is enabled, also attempt to delete existing remote branch
    if force:
        print(f"Attempting to delete existing remote branch {branch_name} on {user_fork}...")
        try:
            run(["git", "push", user_fork, "--delete", branch_name])
        except subprocess.CalledProcessError as e:
            if "remote ref does not exist" in e.stderr:
                print(f"Remote branch '{branch_name}' did not exist. Continuing.")
            else:
                print(f"Warning: failed to delete remote branch: {e.stderr}")

    # Create a temporary worktree
    tmpdir = tempfile.mkdtemp(prefix=f"cherry-pick-{pr_number}-")
    keep_worktree = False
    try:
        print(f"Creating temporary worktree in {tmpdir} based on upstream/{release_branch}...")
        run(["git", "worktree", "add", "-b", branch_name, tmpdir, f"upstream/{release_branch}"])
        
        os.chdir(tmpdir)

        # Cherry-pick the commits
        commit_oids = [c['oid'] for c in pr_info['commits']]
        print(f"Cherry-picking {len(commit_oids)} commits: {', '.join(commit_oids)}")
        try:
            run(["git", "cherry-pick"] + commit_oids)
        except subprocess.CalledProcessError:
            print(f"\n!!! Cherry-pick failed !!!")
            print(f"The temporary worktree has been preserved at: {tmpdir}")
            print("Please resolve the conflicts manually in that directory, then:")
            print("  1. git cherry-pick --continue")
            print("     (Repeat if there are more conflicts in subsequent commits)")
            print(f"  2. git push {user_fork} {branch_name}")
            print(f"  3. gh pr create --title \"{pr_title}\" --body \"{pr_body}\" --base {release_branch} --head {github_username}:{branch_name}")
            print("\nWhen finished, remember to remove the worktree:")
            print(f"  cd {repo_root}")
            print(f"  git worktree remove {tmpdir}")
            keep_worktree = True
            sys.exit(1)

        # Push the new branch
        print(f"Pushing branch {branch_name} to {user_fork}...")
        run(["git", "push", user_fork, f"{branch_name}:refs/heads/{branch_name}"])

        # Create the PR
        print("Creating GitHub Pull Request...")
        pr_output = run(["gh", "pr", "create", "--title", pr_title, "--body", pr_body, "--base", release_branch, "--head", f"{github_username}:{branch_name}"]).stdout.strip()
        print(f"Created PR for cherry-pick: {pr_output}")

    finally:
        os.chdir(repo_root)
        if not keep_worktree:
            print(f"Cleaning up worktree at {tmpdir}...")
            run(["git", "worktree", "remove", tmpdir, "--force"])

if __name__ == "__main__":
    main()
